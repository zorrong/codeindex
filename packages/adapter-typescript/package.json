{
  "name": "@codeindex/adapter-typescript",
  "version": "0.1.0",
  "description": "TypeScript language adapter — uses ts-morph for AST parsing",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@codeindex/core": "workspace:*",
    "ts-morph": "^22.0.0"
  },
  "devDependencies": {
    "vitest": "^1.6.0"
  }
}
