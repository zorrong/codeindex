{
  "name": "codeindex",
  "version": "0.1.0",
  "private": true,
  "description": "Vectorless, reasoning-based code index for AI context retrieval",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @codeindex/cli dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "benchmark": "node benchmarks/run-benchmark.mjs"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "vitest": "^1.6.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0"
  }
}
